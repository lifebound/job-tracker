# PostgreSQL password — used by both the postgres and app containers.
# Change this to a strong unique value before deploying publicly.
POSTGRES_PASSWORD=jobtracker

# Session secret — change to a long random string before deploying publicly.
SESSION_SECRET=dev-local-secret-change-me

# Stale / ghost detection thresholds (days)
STALE_DAYS=3
APPLIED_GHOST_DAYS=21
INTERVIEW_GHOST_DAYS=5

# Optional email alerts (daily cron)
EMAIL_ALERTS_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
