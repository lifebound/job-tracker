# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jobtracker
DB_USER=jobtracker
DB_PASSWORD=jobtracker

# App settings
PORT=3000

# Alert settings: how many days before an application is considered "stale"
STALE_DAYS=3

# Optional email alerts (daily cron)
EMAIL_ALERTS_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# Optional cron log output location
LOG_DIR=./logs
LOG_FILE=cron.log
